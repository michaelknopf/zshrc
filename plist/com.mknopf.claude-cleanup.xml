<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!--
  DISABLED 2026-07-05 — superseded by Claude Code's built-in `cleanupPeriodDays`
  (set to 30 in ~/.claude/settings.json), which prunes a superset of what this
  job did. The <Disabled/> key below stops launchd from loading it at login; the
  script itself also self-guards (see bin/internal/claude-cleanup.sh). Kept for
  reference. To reactivate: set Disabled to <false/>, then `launchctl load` this.
-->
<dict>
    <key>Disabled</key>
    <true/>
    <key>Label</key>
    <string>com.mknopf.claude-cleanup</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/mknopf/code/github/michaelknopf/zshrc/bin/internal/claude-cleanup.sh</string>
    </array>
    <key>StartInterval</key>
    <integer>86400</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/claude-cleanup.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/claude-cleanup.log</string>
</dict>
</plist>
