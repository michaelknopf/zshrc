[
  // Custom: Git Blame — matches IntelliJ's Cmd+Opt+' for Annotate
  {
    "key": "cmd+alt+'",
    "command": "gitlens.toggleFileBlame",
    "when": "editorTextFocus",
  },

  // Markdown: Cmd+Shift+V true toggle — source↔preview without duplicate tabs (requires DarrenJMcLeod.markdown-toggle-preview)
  {
    "key": "cmd+shift+v",
    "command": "markdownToggle.toggleView",
  },

  // Unbind: IntelliJ plugin maps Cmd+K to git.commitAll; drop when-clause for reliable removal
  {
    "key": "cmd+k",
    "command": "-git.commitAll"
  },

  // Unbind: cmd+n opens a new untitled file (scratch) by default; reclaim it for new file in explorer
  {
    "key": "cmd+n",
    "command": "-workbench.action.files.newUntitledFile",
  },

  // New File in Explorer (in the selected folder, not a scratch file)
  {
    "key": "cmd+n",
    "command": "explorer.newFile",
    "when": "explorerViewletFocus",
  },

  // Unbind: cmd+shift+n opens a new window by default; reclaim it for new folder
  {
    "key": "cmd+shift+n",
    "command": "-workbench.action.newWindow",
  },

  // New Folder in Explorer
  {
    "key": "cmd+shift+n",
    "command": "explorer.newFolder",
    "when": "explorerViewletFocus",
  },
]
