{
  // ── Editor ──────────────────────────────────────────────────────────────────
  "editor.fontSize": 14,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.detectIndentation": true,
  "editor.renderWhitespace": "trailing",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.stickyScroll.enabled": true,
  "editor.minimap.enabled": false,
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "editor.linkedEditing": true,
  "editor.wordWrap": "off",
  "editor.rulers": [120],
  "editor.suggestSelection": "first",
  "editor.acceptSuggestionOnCommitCharacter": false,
  // Show inlay hints only when holding Opt — matches IntelliJ's default behavior
  "editor.inlayHints.enabled": "offUnlessPressed",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },

  // ── Files ────────────────────────────────────────────────────────────────────
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  // Auto-save on focus change — IntelliJ saves aggressively; this is the closest equivalent
  "files.autoSave": "onFocusChange",
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/*.pyc": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/.terraform": true
  },
  "files.associations": {
    "*.tf": "terraform",
    "*.tfvars": "terraform",
    "*.hcl": "terraform",
    "Dockerfile.*": "dockerfile",
    ".env*": "dotenv"
  },

  // ── Search ───────────────────────────────────────────────────────────────────
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/.venv": true,
    "**/venv": true,
    "**/.terraform": true,
    "**/coverage": true,
    "**/*.min.js": true
  },
  "workbench.startupEditor": "none",
  "workbench.editor.tabSizing": "shrink",
  "window.zoomLevel": 1,
  "window.openFoldersInNewWindow": "on",
  "workbench.tree.indent": 16,
  // Show every folder level — IntelliJ doesn't collapse intermediary dirs
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,

  // ── Terminal ──────────────────────────────────────────────────────────────────
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.copyOnSelection": true,

  // ── Git ───────────────────────────────────────────────────────────────────────
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.openAfterClone": "always",
  "diffEditor.ignoreTrimWhitespace": false,

  // ── Python ────────────────────────────────────────────────────────────────────
  // Discover .venv in the workspace root — matches uv convention.
  // Note: python.defaultInterpreterPath does not support ${workspaceFolder} in global user
  // settings, so we rely on the Python extension's built-in venv auto-discovery instead.
  "python.terminal.activateEnvironment": true,
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.tabSize": 4,
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "ruff.organizeImports": true,
  // Exclude virtualenv and site-packages from linting/analysis — library code is not ours to fix
  "ruff.exclude": ["**/.venv"],
  // Standard mode is the fallback when no pyrightconfig.json is present in the project
  "python.analysis.typeCheckingMode": "standard",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.inlayHints.functionReturnTypes": true,
  "python.analysis.inlayHints.variableTypes": false,
  "python.analysis.exclude": ["**/.venv"],
  // Monokai colors `async`/`def` as storage.type (cyan #66D9EF), indistinguishable from module teal.
  // Override to pink (#F92672) to match the rest of the keyword palette. Also strip the italic.
  "editor.tokenColorCustomizations": {
    "[Darcula Theme from IntelliJ]": {
      "textMateRules": [
        // Regular strings → bright green (distinguish from muted olive docstrings)
        {
          "scope": [
            "string.quoted.single.python",
            "string.quoted.double.python"
          ],
          "settings": { "foreground": "#6aad56" }
        },
        // None/True/False → blue to signal they're special constants, not plain identifiers
        {
          "scope": ["constant.language.python"],
          "settings": { "foreground": "#569cd6" }
        },
        // Keyword argument names in function calls (e.g. `participant=` in `fn(participant=x)`)
        {
          "scope": ["variable.parameter.function-call.python"],
          "settings": { "foreground": "#FFFFFF" }
        }
      ]
    },
    "[Monokai]": {
      "textMateRules": [
        {
          "scope": [
            "storage.type.function.python",
            "storage.type.function.async.python"
          ],
          "settings": {
            "foreground": "#F92672",
            "fontStyle": ""
          }
        }
      ]
    }
  },
  // Pylance underlines module/namespace tokens by default — remove the underline decoration
  "editor.semanticTokenColorCustomizations": {
    "rules": {
      "module:python": { "foreground": "#4ec9b0", "underline": false },
      "namespace:python": { "foreground": "#4ec9b0", "underline": false },
      "class:python": { "foreground": "#569cd6", "underline": false },
      "type:python": { "foreground": "#569cd6", "underline": false }
    }
  },

  // ── TypeScript / JavaScript ───────────────────────────────────────────────────
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },

  // ── JSON / YAML / TOML / Markdown ─────────────────────────────────────────────
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[yaml]": {
    "editor.tabSize": 2
  },
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "other": "off",
      "comments": "off",
      "strings": "off"
    }
  },
  // Open .md files directly in preview (reader) mode — Cmd+Shift+V to toggle back to source
  "workbench.editorAssociations": {
    "*.md": "vscode.markdown.preview.editor"
  },

  // ── Terraform ─────────────────────────────────────────────────────────────────
  "[terraform]": {
    "editor.defaultFormatter": "hashicorp.terraform",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },
  "[terraform-vars]": {
    "editor.defaultFormatter": "hashicorp.terraform",
    "editor.tabSize": 2
  },

  // ── GitLens ───────────────────────────────────────────────────────────────────
  "gitlens.currentLine.enabled": true,
  // Code lens (above functions) is noisy; toggle blame manually with Cmd+Opt+'
  "gitlens.codeLens.enabled": false,
  "gitlens.hovers.currentLine.over": "line",

  // ── Error Lens ────────────────────────────────────────────────────────────────
  "errorLens.gutterIconsEnabled": true,
  "errorLens.messageMaxChars": 120,

  // ── Red Hat (YAML extension) ──────────────────────────────────────────────────
  "redhat.telemetry.enabled": false,
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "claudeCode.preferredLocation": "panel",
  "window.nativeTabs": true,
  "window.title": "${rootName}",
  "claudeCode.allowDangerouslySkipPermissions": true,
  "claudeCode.enableNewConversationShortcut": true,
  // Monokai's default background is #272822 (dark olive); override to pure black
  "workbench.colorCustomizations": {
    "[Monokai]": {
      "editor.background": "#000000",
      "editorGutter.background": "#000000",
      "editorLineNumber.foreground": "#555555",
      "sideBar.background": "#1a1a1a",
      "activityBar.background": "#0a0a0a",
      "panel.background": "#0a0a0a",
      "terminal.background": "#000000",
      "tab.inactiveBackground": "#0a0a0a",
      "tab.activeBackground": "#000000",
      "titleBar.activeBackground": "#0a0a0a"
    }
  },
  "workbench.colorTheme": "Darcula Theme from IntelliJ",
  // just-lsp has too many false positives and no inline suppression mechanism;
  // disable it and keep syntax highlighting only
  "vscode-just.lspPath": "",
  "[just]": {},
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "security.workspace.trust.untrustedFiles": "open"
}
