{
  "allowedTools": [
    "Search",
    "Read",
    "WebSearch"
  ],
  "alwaysThinkingEnabled": false,
  "enabledPlugins": {
    "beads@beads-marketplace": true,
    "feature-dev@claude-plugins-official": true,
    "oracle@oracle": true,
    "pyright-lsp@claude-plugins-official": true,
    "savi@savi-tools": true
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime --stealth",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime --stealth",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "model": "opusplan",
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "Fetch",
      "Search",
      "Read",
      "Bash(just:*)",
      "Bash(pnpm:*)",
      "Bash(docker:*)",
      "Bash(go:*)",
      "Bash(./bin:*)",
      "Bash(curl:*)",
      "Bash(docker:*)",
      "Bash(cat:*)",
      "Bash(lsof:*)",
      "Bash(tree:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(gh:*)",
      "Bash(jq:*)"
    ],
    "ask": [],
    "defaultMode": "bypassPermissions",
    "deny": []
  },
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "~/.claude/statusline.sh",
    "type": "command"
  }
}