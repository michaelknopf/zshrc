# Ignore everything by default — Claude generates tons of ephemeral data
*

# Allow the files we deliberately track
!.gitignore
!CLAUDE.md
!settings.json
!statusline.sh

# Allow specific nested paths (must unignore each directory level)
!archive/
!archive/agents/
!archive/agents/Debugger.md
!docs/
!docs/notes/
!docs/notes/session-2026-01-27-claude-code-startup-optimization.md
!plugins/
!plugins/config.json

# User-authored content — track all files recursively
!agents/
!agents/**
!commands/
!commands/**
!rules/
!rules/**
!skills/
!skills/**
