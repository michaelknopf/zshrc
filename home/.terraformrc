# Shared provider plugin cache.
#
# Without this, every `.terraform/` directory downloads its own copy of every
# provider (the AWS provider alone is ~700 MiB). Across a repo like
# infra-terraform with 30+ module/stack initializations, that's tens of GiB of
# pure duplication. With this set, Terraform/OpenTofu downloads each
# provider/version once into the cache and symlinks it into each `.terraform/`.
plugin_cache_dir = "$HOME/.terraform.d/plugin-cache"

# The cache hits on (provider, version, platform). Lockfiles in this repo pin
# checksums for both darwin and linux platforms (CI runs on linux). When only
# the darwin slice is in the cache, init would otherwise fall back to a full
# download to populate linux checksums. This flag lets init populate missing
# platform checksums into the lockfile from cached providers, avoiding the
# redundant download. Safe in single-developer/team contexts.
plugin_cache_may_break_dependency_lock_file = true
